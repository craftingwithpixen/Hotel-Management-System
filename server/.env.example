# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hospitalityos

# JWT
ACCESS_TOKEN_SECRET=your_access_token_secret_64_chars_min
REFRESH_TOKEN_SECRET=your_refresh_token_secret_64_chars_min
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gmail (SMTP via Nodemailer)
# Create a Google App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM_NAME=Grand Paradise
EMAIL_FROM=youraddress@gmail.com

# App
# Local: http://localhost:5173
# Production: your Vercel site (https), NOT the Render API URL — QR codes embed this host.
FRONTEND_URL=http://localhost:5173
PORT=5000
NODE_ENV=development
COOKIE_DOMAIN=localhost
